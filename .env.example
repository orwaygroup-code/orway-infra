# Infra compartida — copiar a .env y rellenar. NO commitear el .env real.

# Email para los certificados Let's Encrypt (avisos de expiración).
ACME_EMAIL=ops@tudominio.com

# Postgres compartido (superusuario del servidor; cada app usa su propia BD/usuario).
POSTGRES_USER=orway
POSTGRES_PASSWORD=cambia-esto-por-uno-fuerte

# Dominio público de n8n (DNS apuntando al VPS).
N8N_HOST=n8n.tudominio.com
