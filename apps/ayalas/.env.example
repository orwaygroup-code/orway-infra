# Una instancia de Ayalas (un cliente). Copiar a <cliente>.env y rellenar.
# NO commitear el .env real.

# Identidad de la instancia (usadas por Traefik en las labels del compose).
CLIENT=ayalas
DOMAIN=ayalas.tudominio.com

# Base de datos del cliente (host = `postgres`, la red interna del VPS).
DATABASE_URL=postgresql://ayalas:cambia-esto@postgres:5432/ayalas_db?schema=public

# Secreto de la cookie de sesión (>=32 chars). Genera: openssl rand -base64 32
SESSION_SECRET=cambia-esto-por-un-secreto-largo-de-32+

# Admin inicial del CRM (lo crea el seed).
ADMIN_EMAIL=admin@ayalas.mx
ADMIN_PASSWORD=cambia-esto
ADMIN_NAME=Administrador

# Clave compartida con n8n (header x-bot-key). Genera: openssl rand -hex 16
BOT_API_KEY=cambia-esta-clave

# Meta / OpenAI NO van aquí — son Credentials de n8n.
META_GRAPH_VERSION=v25.0
GYM_TIMEZONE=America/Mexico_City
