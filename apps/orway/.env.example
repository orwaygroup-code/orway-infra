# Orway System — instancia del VPS. Copiar a .env y rellenar. NO commitear el .env real.

# Dominio (lo usa Traefik en las labels y la app). DNS ya apunta al VPS:
# apex (orwaygroup.com) y www. Orway sirve ambos y reemplaza la landing anterior.
DOMAIN=orwaygroup.com

# --- Base de datos (Postgres COMPARTIDO; host interno `postgres`) ---
# Orway usa DOS roles dentro de su propia BD:
#   OWNER  -> migraciones / seed
DATABASE_URL=postgresql://orway_integral:CAMBIAME_OWNER@postgres:5432/orway_integral_db
#   APP    -> runtime, mínimo privilegio + RLS
DATABASE_URL_APP=postgresql://orway_app:CAMBIAME_APP@postgres:5432/orway_integral_db

# Secreto de la cookie de sesión (>=32). Genera: openssl rand -base64 48
SESSION_SECRET=

# Orway Cloud: ruta dentro del contenedor (montada al volumen orway_storage).
STORAGE_DIR=/data/storage

# Clave compartida con n8n (header x-bot-key). Genera: openssl rand -hex 16
BOT_API_KEY=

NODE_ENV=production
